# Build artifacts from the core tools, if a contributor runs them in-tree.
# Generated datasets (forge), checkpoints/adapters (anvil), eval reports (crucible).
/data/
data/raw/
datasets/
checkpoints/
reports/
*.safetensors
*.gguf

# ...but DO keep the committed sample SFT dataset fixture (small, deterministic,
# real forge offline output). It lives under go/datasets/ and is tracked on
# purpose; see go/datasets/code_guild_sample_v1/DATASET_CARD.md.
!go/datasets/
!go/datasets/**

# Python / tooling caches (if helper scripts are run here)
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Editor / OS
.idea/
.vscode/
.DS_Store

