# Build artifacts from the core tools, if a contributor runs them in-tree.
# Generated datasets (forge), checkpoints/adapters (anvil), eval reports (crucible).
/data/
data/raw/
datasets/
checkpoints/
reports/
*.safetensors
*.gguf

# ...but DO keep the committed sample SFT dataset fixture (small, deterministic,
# real forge offline output). It lives under go/datasets/ and is tracked on
# purpose; see go/datasets/code_guild_sample_v1/DATASET_CARD.md.
!go/datasets/
!go/datasets/**

# Python / tooling caches (if helper scripts are run here)
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Editor / OS
.idea/
.vscode/
.DS_Store

# Continued-pretraining corpus (regenerated from $GOROOT/src; too big to commit)
go/datasets/pretrain/go_corpus.jsonl

# GitHub Go mining pipeline (go/datasets/mining): cloned repo cache + large
# generated corpora are regenerated on demand and far too big to commit. The
# scripts, README, and small *.sample.jsonl files ARE tracked.
go/datasets/mining/repos/
go/datasets/mining/repos.jsonl
go/datasets/mining/repos.smoke.jsonl
go/datasets/mining/go_dapt_mined.jsonl
go/datasets/mining/mined_dev.jsonl
go/datasets/mining/mined_bugfix.jsonl
go/datasets/mining/mined_review.jsonl
go/datasets/mining/mined_commits.jsonl
go/datasets/mining/*.log
go/datasets/mining/go_dapt_core.jsonl
